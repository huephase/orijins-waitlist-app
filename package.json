{
  "name": "restaurant-waitlist-app",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm run build:css && tsc && npm run copy:views",
    "build:css": "sass public/scss/main.scss public/css/main.css --style=compressed",
    "copy:views": "cpx \"src/views/**/*\" dist/views",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,js,json,md,njk,scss,yml}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^10.0.0",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "nunjucks": "^3.2.4",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nunjucks": "^3.2.6",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "cpx": "^1.5.0",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "sass": "^1.83.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "@types/express-serve-static-core": "4.19.8"
  }
}
